# Configuración de URLs Productivas (VPS & EasyPanel)

# URL de Qdrant expuesto en EasyPanel
QDRANT_URL="https://your-qdrant.easypanel.host/"
# API Key de Qdrant (opcional)
QDRANT_API_KEY=""

# URL de MLflow (dejar vacío para desactivar)
MLFLOW_TRACKING_URI=""

# URL base de Ollama Cloud
OLLAMA_BASE_URL="https://ollama.com"

# API Key de Ollama Cloud
OLLAMA_API_KEY="your-ollama-cloud-api-key"

# CORS: Orígenes permitidos separados por coma
CORS_ORIGINS="*"

# API Key de Google Gemini (para embeddings)
GOOGLE_API_KEY="your-google-api-key"
